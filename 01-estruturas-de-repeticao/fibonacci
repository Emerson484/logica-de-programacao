# include <iostream>
using namespace std;
int main(){

  int anterior1=0,anterior2=1,quant,resultado;
  
  cout<<"digite o numero da sequencia"<<endl;
  cin>>quant;
  
  cout<<anterior1<<endl;
  cout<<anterior2<<endl;
  
  for(int i=2;i<quant;i++){
     resultado=anterior1+anterior2;
     cout<<resultado<<endl;
     anterior1=anterior2;
     anterior2=resultado;
  }
  //0 1 1 2 3 5 8
  return(0);
}
